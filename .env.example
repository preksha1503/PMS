# Copy this file to `.env` and fill in your values.

# =========================
# DJANGO SETTINGS
# =========================
SECRET_KEY=replace-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# =========================
# DATABASE CONFIG
# =========================
# Options: mysql / sqlite
DB_ENGINE=mysql

# MySQL Config
DB_NAME=pms_new
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306

# =========================
# AUTH REDIRECTS
# =========================
LOGIN_URL=login
LOGIN_REDIRECT_URL=dashboard
LOGOUT_REDIRECT_URL=login

